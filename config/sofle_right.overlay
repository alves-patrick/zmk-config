&i2c0 {
    status = "okay";
    clock-frequency = <100000>; // Tente uma velocidade menor de I2C

    trackpad: tps43@44 {
        compatible = "azoteq,tps43";
        reg = <0x44>;
        irq-gpios = <&gpio1 7 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        resolution = <800>;
        /* Adicione estas linhas para forçar a detecção */
        status = "okay";
    };
};
